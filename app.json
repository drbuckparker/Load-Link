{
  "expo": {
    "name": "LoadLink",
    "slug": "loadlink",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "loadlink",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "runtimeVersion": "1.0.2",
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#161a22"
    },
    "ios": {
      "supportsTablet": false,
      "requireFullScreen": true,
      "bundleIdentifier": "com.loadlink.app"
    },
    "android": {
      "package": "com.loadlink.app",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyD0k24WGEPooosI-AB0dkewtiBTp_DScdI"
        }
      },
      "adaptiveIcon": {
        "backgroundColor": "#161a22",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "LoadLink uses your location to verify you are at the job site when you clock in and out, to show nearby trucking jobs sorted by distance, to auto-fill pickup and drop-off addresses when you post a job, and — only while you are clocked in — to remind you if you leave the job site without clocking out. For example, when you tap Clock In at a delivery site, your current location confirms your arrival.",
          "isIosBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "sounds": ["./assets/sounds/truckhorn.wav"]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {
        "origin": "https://replit.com/"
      },
      "eas": {
        "projectId": "06835a51-8023-416f-948f-d8450c3495bf"
      }
    },
    "owner": "load-link"
  }
}
